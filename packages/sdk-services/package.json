{
  "name": "@tinycloud/sdk-services",
  "version": "2.7.0-beta.4",
  "description": "TinyCloud SDK Services - Platform-agnostic service implementations",
  "author": "TinyCloud, Inc.",
  "license": "EGPL",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "main": "dist/index.cjs",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./kv": {
      "types": "./dist/kv/index.d.ts",
      "import": "./dist/kv/index.js",
      "require": "./dist/kv/index.cjs"
    },
    "./sql": {
      "types": "./dist/sql/index.d.ts",
      "import": "./dist/sql/index.js",
      "require": "./dist/sql/index.cjs"
    },
    "./encryption": {
      "types": "./dist/encryption/index.d.ts",
      "import": "./dist/encryption/index.js",
      "require": "./dist/encryption/index.cjs"
    },
    "./internal/decrypt-transport-response-error": {
      "types": "./dist/internal/decrypt-transport-response-error.d.cts",
      "import": "./dist/internal/decrypt-transport-response-error.cjs",
      "require": "./dist/internal/decrypt-transport-response-error.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "bun test"
  },
  "dependencies": {
    "@tinycloud/bootstrap": "2.6.0-beta.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@tinycloud/node-sdk-wasm": "1.7.5-beta.0",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/tinycloudlabs/web-sdk"
  }
}
