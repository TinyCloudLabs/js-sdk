{
  "name": "@tinycloud/cli",
  "version": "0.8.1",
  "description": "TinyCloud CLI - manage data, delegations, and nodes from the terminal",
  "author": "TinyCloud, Inc.",
  "license": "EGPL",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "tc": "./bin/tc"
  },
  "files": [
    "dist",
    "bin"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "dev": "tsup --watch",
    "generate:reference": "bun scripts/generate-reference.ts",
    "check:generated": "bun scripts/generate-reference.ts --check",
    "check:coverage": "bun scripts/check-coverage.ts",
    "smoke:delegated-secrets": "bun scripts/live-delegated-secrets-smoke.ts"
  },
  "dependencies": {
    "@tinycloud/node-sdk": "2.9.0",
    "@tinycloud/node-sdk-wasm": "1.7.5",
    "@tinycloud/operations": "0.3.0",
    "chalk": "^5.3.0",
    "commander": "^14.0.0",
    "open": "^11.0.0",
    "ora": "^9.3.0",
    "siwe": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "^20",
    "tsup": "^8.0.0",
    "typescript": "^5.9.3"
  }
}
