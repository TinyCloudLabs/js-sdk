---
import Atlas from '@/layouts/Atlas.astro';
import { getInventory, getAllPackages } from '@/lib/atlas';

const inv = await getInventory();
const pkgs = await getAllPackages();
const ch = inv.chapters.find(c => c.id === '01')!;

// Group packages onto the three-surface diagram lanes.
const surfaces = pkgs.filter(p => p.side === 'browser' || p.side === 'node' || p.side === 'cli');
const core     = pkgs.filter(p => p.kind === 'core' || p.kind === 'services');
const wasm     = pkgs.filter(p => p.kind === 'rust' || p.kind === 'wasm');
---
<Atlas chapter="01" title={ch.title} crumb={`01 · ${ch.title}`}>
  <article class="prose" style="padding: 56px 64px; max-width: 1100px;">
    <div class="label">chapter 01 · {ch.read} · voice: {ch.voice}</div>
    <h1 style="margin-top: 14px;">three surfaces, <span class="squig">one core</span></h1>
    <p>
      Every TinyCloud SDK consumer sits on one of three surfaces — a browser app, a
      Node service, or the <code>tc</code> CLI. They <em>look</em> like different
      products, but they're three faces of the same engine. Underneath, they all
      consume <a class="pkg-link" href={`${import.meta.env.BASE_URL.replace(/\/$/,'')}/pkg/sdk-core/`}>sdk-core</a>,
      and ultimately delegate to the Rust kernel via wasm.
    </p>

    <div class="mermaid-wrap" style="margin: 28px 0; height: 420px; position: relative;">
      <span class="cap">surfaces.svg</span>

      <!-- three surfaces row -->
      <div class="row gap-16" style="position: absolute; top: 36px; left: 32px; right: 32px;">
        {surfaces.map((p, i) => (
          <a href={`${import.meta.env.BASE_URL.replace(/\/$/,'')}/pkg/${p.id.replace(/\//g,'--')}/`}
             class="gnode" style={{ position:'relative', flex:1, top:0, left:0 }}>
            <div class="name">{p.npm}</div>
            <div class="meta">{p.side} · {p.modules} mod · {p.loc.toLocaleString()} loc</div>
          </a>
        ))}
      </div>

      <!-- arrows down -->
      <svg style="position: absolute; top: 110px; left: 0; right: 0; width: 100%; height: 70px;">
        <defs>
          <marker id="ah" viewBox="0 0 10 10" refX="9" refY="5" markerWidth="6" markerHeight="6" orient="auto">
            <path d="M0,0 L10,5 L0,10 z" fill="var(--accent)" />
          </marker>
        </defs>
        {surfaces.map((_, i) => {
          const x = (i + 0.5) * (100 / surfaces.length);
          return <line x1={`${x}%`} y1="0" x2={`${x}%`} y2="60" stroke="var(--accent)" stroke-width="1.4" stroke-dasharray="4 4" marker-end="url(#ah)" />;
        })}
      </svg>

      <!-- core row -->
      <div class="row gap-16 center" style="position: absolute; top: 200px; left: 32px; right: 32px;">
        {core.map(p => (
          <a href={`${import.meta.env.BASE_URL.replace(/\/$/,'')}/pkg/${p.id.replace(/\//g,'--')}/`}
             class="gnode" style={{ position:'relative', flex:1, top:0, left:0, background:'var(--accent)', color:'var(--paper)', borderColor:'var(--accent)' }}>
            <div class="name">{p.npm}</div>
            <div class="meta" style="color: rgba(255,255,255,0.85);">{p.kind} · {p.modules} mod</div>
          </a>
        ))}
      </div>

      <!-- arrows down to wasm -->
      <svg style="position: absolute; top: 270px; left: 0; right: 0; width: 100%; height: 70px;">
        <line x1="50%" y1="0" x2="50%" y2="60" stroke="var(--ink-3)" stroke-width="1.4" stroke-dasharray="4 4" marker-end="url(#ah)" />
      </svg>

      <!-- wasm row -->
      <div class="row gap-16 center" style="position: absolute; top: 350px; left: 32px; right: 32px; justify-content: center;">
        {wasm.map(p => (
          <a href={`${import.meta.env.BASE_URL.replace(/\/$/,'')}/pkg/${p.id.replace(/\//g,'--')}/`}
             class="gnode" style={{ position:'relative', flex:'0 0 auto', top:0, left:0, background:'var(--ink)', color:'var(--paper)', borderColor:'var(--ink)' }}>
            <div class="name">{p.id}</div>
            <div class="meta" style="color: rgba(255,255,255,0.65);">{p.kind} · {p.side}</div>
          </a>
        ))}
      </div>

      <div class="callout" style="top: 116px; right: 16px; transform: rotate(2deg);">
        the seam — <br/>everything below this line is rust.
      </div>
    </div>

    <h2>what each surface contributes</h2>
    <p>
      {pkgs.find(p => p.id==='web-sdk')?.why}
    </p>
    <p>
      {pkgs.find(p => p.id==='node-sdk')?.why}
    </p>
    <p>
      {pkgs.find(p => p.id==='cli')?.why}
    </p>

    <h2>and the core they share</h2>
    <p>
      {pkgs.find(p => p.id==='sdk-core')?.why}
    </p>

    <h3>where to read next</h3>
    <p>
      Chapter <a class="pkg-link" href={`${import.meta.env.BASE_URL.replace(/\/$/,'')}/02/`}>02</a> opens
      the wasm seam itself — the IWasmBindings interface and what crosses it.
      If you'd rather see the package internals first, jump straight to
      any package in the left rail.
    </p>
  </article>
</Atlas>
